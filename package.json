{
  "name": "workbuddian",
  "version": "1.0.13",
  "description": "第三方 Obsidian 插件，桥接本地 WorkBuddy/CodeBuddy Gateway",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "workbuddy",
    "codebuddy",
    "gateway",
    "knowledge-base"
  ],
  "author": "jiang198012",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jiang198012/workbuddian.git"
  },
  "homepage": "https://github.com/jiang198012/workbuddian#readme",
  "bugs": {
    "url": "https://github.com/jiang198012/workbuddian/issues"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^16.11.6",
    "esbuild": "0.17.3",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "obsidian": "latest",
    "ts-jest": "^29.0.0",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  }
}
